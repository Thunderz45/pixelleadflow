{
  "manifest_version": 3,
  "name": "LeadFlow Agent",
  "version": "1.0.0",
  "description": "Companion scraper extension for LeadFlow SaaS. Extract B2B leads from Google Maps.",
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://*.google.com/maps/*",
    "https://pixelleadflow.vercel.app/*",
    "https://pixel-leadflow.firebaseapp.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://www.google.co.in/maps/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
